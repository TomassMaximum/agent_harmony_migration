{
  "agent": {
    "model": "deepseek-chat",
    "max_steps": 80,
    "root": ".",
    "session_storage_path": "./sessions",
    "chat_storage_path": "./chats"
  },
  "llm": {
    "api_key": "",
    "base_url": "https://api.deepseek.com/chat/completions",
    "timeout": 120,
    "temperature": null,
    "max_tokens": null
  },
  "tools": {
    "run_command": {
      "timeout": 60
    },
    "search_text": {
      "max_results": 30
    },
    "read_file": {
      "max_chars": 12000
    }
  },
  "web": {
    "host": "0.0.0.0",
    "port": 5001,
    "debug": true
  },
  "scripts": {
    "chat_agent": {
      "default_max_steps": 800
    }
  }
}
